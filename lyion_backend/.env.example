# =============================================================================
# .env.example — Copy to .env and fill in your values.
# Never commit the actual .env file.
# =============================================================================

# Flask
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-string

# PostgreSQL connection
DATABASE_URL=postgresql://lyion:lyion_pass@db:5432/lyion_db

# JWT
JWT_SECRET_KEY=replace-with-another-long-random-string

# Station authentication (must match STATION_API_KEY on the RPi)
STATION_API_KEY=replace-with-station-secret

STATION_ID=station-001

# Institution-specific settings
SCHOOL_NAME=My University
SCHOOL_LOGO_URL=https://my-university.edu/logo.png
DEPOSIT_AMOUNT=5.00
MAX_RENTAL_HOURS=24
BATTERY_CHARGE_THRESHOLD=80
